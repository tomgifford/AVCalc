# Copy this file to .env and fill in the values.
# Generate a session secret with: openssl rand -hex 32

PORT=3000
NODE_ENV=production
SESSION_SECRET=replace-with-output-of-openssl-rand-hex-32

# CORS origins are only relevant in local development.
# In production the app is served same-origin so CORS is not needed.
CORS_ORIGINS=http://localhost:5173,http://localhost:5174
